# React Application Environment Variables
# Copy this file to .env and update values for your environment

# API Configuration
VITE_API_URL=https://localhost:5001/api

# Azure AD Configuration (for internal ops)
VITE_AAD_CLIENT_ID=your-azure-ad-client-id
VITE_AAD_TENANT_ID=your-azure-ad-tenant-id
VITE_AAD_REDIRECT_URI=http://localhost:5173/ops/callback

# Stripe Configuration (for future ACH integration)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Application Settings
VITE_APP_NAME=Think Funding
VITE_COMPANY_NAME=Think Funding LLC
